@model SafetyAndSecurityForNSI.Models.GovernmentJob
@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div>
    <h4 class="text-center">Job Details</h4>
</div>
@if (Model != null)
{
    <div class="row">
        <div class="col-xs-12 col-md-12">
            <div class="form-group">
                <label class="col-xs-3 col-md-3 control-label">Department</label>
                <div class="col-xs-9 col-md-9">
                    @Html.DisplayFor(model => model.DepartmentName, new { @class = "form-control" })
                </div>
            </div>
            <div class="form-group">
                <label class="col-xs-3 col-md-3 control-label">Job Title</label>
                <div class="col-xs-9 col-md-12">
                    @Html.DisplayFor(model => model.Job_Title, new { @class = "form-control" })
                </div>
            </div>
            <div class="form-group">
                <label class="col-xs-3 col-md-3 control-label">Created Date</label>
                <div class="col-xs-9 col-md-12">
                    @Convert.ToDateTime(Model.CreatedDate).ToString("MMM dd,yyyy hh:mm tt")
                </div>
            </div>
            <div class="form-group">
                <label class="col-xs-3 col-md-3 control-label">Body</label>
                <div class="col-xs-9 col-md-12">
                    @Html.Raw(Model.Body)
                </div>
            </div>
        </div>
    </div>
}
else
{
<h4>No record to display</h4>
}
